# PayOps Platform — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=payops
POSTGRES_USER=payops
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_EXPIRY=1h

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=payops
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000
