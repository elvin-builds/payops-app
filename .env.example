# ─── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=payops
POSTGRES_USER=payops
POSTGRES_PASSWORD=change-me

# ─── RabbitMQ ───────────────────────────────────────
RABBITMQ_USER=payops
RABBITMQ_PASSWORD=change-me

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=1h

# ─── Application ────────────────────────────────────
NODE_ENV=development
